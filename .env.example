# =============================================================================
# TEND+ Environment Variables
# =============================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values below
# 3. NEVER commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk (Authentication)
# https://clerk.com
# -----------------------------------------------------------------------------
# Publishable key - safe to expose in client (NEXT_PUBLIC_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Secret key - server only, NEVER expose
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Webhook signing secret for /api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# -----------------------------------------------------------------------------
# Supabase (Database)
# https://supabase.com
# -----------------------------------------------------------------------------
# Project URL - safe to expose (NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous key - safe to expose, used for RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key - server only, bypasses RLS (admin only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Upstash Redis (Rate Limiting)
# https://upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# -----------------------------------------------------------------------------
# Google Gemini (AI)
# https://ai.google.dev
# ⚠️ NEVER add NEXT_PUBLIC_ prefix - keep server-side only
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# -----------------------------------------------------------------------------
# Cron Jobs (Vercel Cron)
# https://vercel.com/docs/cron-jobs
# -----------------------------------------------------------------------------
# Secret to validate cron requests (set in Vercel dashboard)
CRON_SECRET=your_cron_secret

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Fail open threshold - after N failures, rate limiter returns "deny"
RATE_LIMIT_FAIL_OPEN_THRESHOLD=20

# -----------------------------------------------------------------------------
# Encryption (Health Profile Data)
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# -----------------------------------------------------------------------------
# Phase Verification (internal)
# -----------------------------------------------------------------------------
CURRENT_PHASE=3

# -----------------------------------------------------------------------------
# MFDS (식약처 API) - Phase 4
# -----------------------------------------------------------------------------
MFDS_API_KEY=your_mfds_api_key

# -----------------------------------------------------------------------------
# Resend (Email) - Phase 13
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key

# -----------------------------------------------------------------------------
# Admin Configuration
# Comma-separated list of admin emails for fallback admin check
# -----------------------------------------------------------------------------
ADMIN_EMAILS=admin@example.com
